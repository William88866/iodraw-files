    <mxGraphModel dx="1011" dy="635" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;论文诚信检测系统 — 技术流程图&lt;/font&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n_start" value="&lt;b style=&quot;font-size: 20px;&quot;&gt;PDF解析完成&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=20;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="80" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n_step1" value="&lt;b style=&quot;font-size: 22px;&quot;&gt;第一步：文本采样与预处理&lt;/b&gt;&lt;div style=&quot;font-size: 22px;&quot;&gt;&lt;br style=&quot;font-size: 22px;&quot;&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=22;align=center;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="210" y="160" width="300" height="210" as="geometry" />
        </mxCell>
        <mxCell id="n_step2" value="&lt;b&gt;第二步：启发式信号分组扫描&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;• 5组正则表达式模式匹配全文&lt;br&gt;• 每组信号独立权重计分&lt;br&gt;• 检测负面信号（综述/纯理论/无实验等）并扣分&lt;br&gt;• 同步计算实验章节完整度&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="575" y="585" width="350" height="95" as="geometry" />
        </mxCell>
        <mxCell id="n_signal" value="&lt;b&gt;五组检测信号&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;① 算法/伪代码/复杂度 (w=1.0)&lt;br&gt;② 实现/源代码/开源仓库 (w=1.1)&lt;br&gt;③ 实验/基准/数据集/指标 (w=1.0)&lt;br&gt;④ ML系统/训练/推理 (w=0.9)&lt;br&gt;⑤ 复现/可复现/补充材料 (w=0.8)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;dashed=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="970" y="570" width="210" height="125" as="geometry" />
        </mxCell>
        <mxCell id="e_signal" style="edgeStyle=none;dashed=1;strokeColor=#d6b656;" edge="1" parent="1" source="n_step2" target="n_signal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_decision1" value="&lt;b&gt;扫描得分 ≥ 3 ?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="640" y="720" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n_yes1" value="&lt;b&gt;直接判定「可复现」&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;assessment_mode = scan&lt;br&gt;confidence = 0.5 + weighted×0.07&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="795" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n_decision2" value="&lt;b&gt;LLM是否已配置?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="640" y="840" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n_llm_yes" value="&lt;b&gt;LLM深度研判&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;• 发送约14,000字上下文给LLM&lt;br&gt;• 输出JSON: reproducible/confidence/reason/signals&lt;br&gt;• assessment_mode = scan+llm&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="830" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n_llm_no" value="&lt;b&gt;启发式结果输出&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;• confidence = 0.35~0.4&lt;br&gt;• 提示用户配置LLM Key&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="910" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="n_final" value="&lt;b&gt;第四步：报告聚合与前端渲染&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;• 融合启发式扫描 + LLM研判结果&lt;br&gt;• 统一输出结构化JSON检测报告&lt;br&gt;• 前端论文检测页面渲染可视化风险卡片&lt;br&gt;• 每份报告标注免责声明&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="965" width="400" height="95" as="geometry" />
        </mxCell>
        <mxCell id="n_end" value="&lt;b&gt;检测完成&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="675" y="1100" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="n_note" value="&lt;font style=&quot;font-size: 10px;color:#999;&quot;&gt;⚠ 每份检测报告均标注：「自动化检测结果仅供辅助参考，不构成官方学术不端认定」&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;dashed=1;" vertex="1" parent="1">
